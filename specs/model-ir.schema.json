{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/bayes-canvas/model-ir.schema.json",
  "title": "Bayes Canvas Model IR",
  "type": "object",
  "required": ["version", "model", "nodes", "edges"],
  "properties": {
    "version": { "type": "string" },
    "model": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "plates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "index", "size"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "index": { "type": "string" },
          "size": { "type": "string" }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "name"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["data", "parameter", "hyperparameter", "latent", "deterministic", "likelihood"]
          },
          "name": { "type": "string" },
          "shape": { "type": "array", "items": { "type": "string" } },
          "observed": { "type": "boolean" },
          "plate": { "type": "string" },
          "distribution": {
            "type": "object",
            "required": ["id", "name", "args"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Canonical distribution registry ID, independent of any backend PPL."
              },
              "name": { "type": "string" },
              "args": { "type": "object", "additionalProperties": { "type": "string" } }
            }
          },
          "expression": { "type": "string" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "role"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    }
  }
}
