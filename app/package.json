{
  "name": "bayes-canvas-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc",
    "lint": "npm run typecheck",
    "test": "tsc -p tsconfig.test.json && node --experimental-specifier-resolution=node --test test/*.test.mjs",
    "cli:build": "tsc -p tsconfig.cli.json",
    "cli:lint:sample": "npm run cli:build && node --experimental-specifier-resolution=node bin/bayes-canvas.mjs lint --sample",
    "cli:handoff:sample": "npm run cli:build && node --experimental-specifier-resolution=node bin/bayes-canvas.mjs handoff --sample --target pymc",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xyflow/react": "12.11.1",
    "elkjs": "^0.11.1",
    "katex": "^0.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "6.0.3",
    "vite": "8.1.0"
  }
}
